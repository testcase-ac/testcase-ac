# Source of problem data.
# Points at the repo root that contains testcase/.
TESTCASE_LOCAL_PATH=

# Stresser: local_docker | lambda
STRESSER_MODE=local_docker

# local_docker: endpoint of a locally-running stresser container
STRESSER_LOCAL_ENDPOINT=http://localhost:9000/2015-03-31/functions/function/invocations

# lambda: function name + region
STRESSER_LAMBDA_FUNCTION_NAME=testcase-ac-stresser
AWS_REGION=ap-northeast-2

# Submission rate limit
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_S=10

# Comma-separated allowed origins for CORS. Empty string disables CORS.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://testcase-ac.github.io,https://next.testcase.ac,https://testcase.ac

# Server bind address.
HTTP_ADDR=127.0.0.1:8000
